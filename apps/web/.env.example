# Browser-trace OTLP/HTTP endpoint. Empty here = off for local `vite` dev.
# Published images also keep this empty. Supply a collector you control via the
# Docker build argument only when browser tracing is intentionally enabled.
VITE_OTEL_EXPORTER_OTLP_ENDPOINT=
VITE_OTEL_SERVICE_NAME=ironrag-web
VITE_OTEL_SERVICE_VERSION=
VITE_OTEL_DEPLOYMENT_ENVIRONMENT=development
# React Query devtools are excluded from ordinary UI sessions unless opted in.
VITE_ENABLE_QUERY_DEVTOOLS=false
