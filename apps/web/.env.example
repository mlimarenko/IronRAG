# Browser-trace OTLP/HTTP endpoint. Empty here = off for local `vite` dev.
# The shipped frontend image bakes the maintainers' collector as the default
# (apps/web/Dockerfile build arg); override or empty it there to change that.
VITE_OTEL_EXPORTER_OTLP_ENDPOINT=
VITE_OTEL_SERVICE_NAME=ironrag-web
VITE_OTEL_SERVICE_VERSION=
VITE_OTEL_DEPLOYMENT_ENVIRONMENT=development
