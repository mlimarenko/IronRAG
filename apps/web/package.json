{
  "name": "ironrag-frontend",
  "private": true,
  "version": "0.5.12",
  "packageManager": "npm@11.17.0",
  "type": "module",
  "engines": {
    "node": ">=26.0.0 <27"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "duplication:engine-check": "jscpd --version",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "swagger:sync": "node scripts/sync-swagger-ui.mjs",
    "swagger:check": "node scripts/sync-swagger-ui.mjs --check",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run && npm run test:scripts",
    "test:scripts": "node --test scripts/*.test.mjs",
    "test:coverage": "vitest run --coverage && npm run test:scripts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "bundle:check": "node scripts/check-bundle-budget.mjs",
    "size-limit": "size-limit",
    "deadcode:ts-prune": "ts-prune"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-zone-peer-dep": "^2.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/instrumentation": "^0.220.0",
    "@opentelemetry/instrumentation-document-load": "^0.65.0",
    "@opentelemetry/instrumentation-fetch": "^0.220.0",
    "@opentelemetry/instrumentation-user-interaction": "^0.64.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-scroll-area": "^1.2.13",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.16",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@sigma/edge-curve": "^3.1.0",
    "@tanstack/react-query": "^5.101.2",
    "@tiptap/extension-image": "^3.25.0",
    "@tiptap/extension-table": "^3.25.0",
    "@tiptap/extension-table-cell": "^3.25.0",
    "@tiptap/extension-table-header": "^3.25.0",
    "@tiptap/extension-table-row": "^3.25.0",
    "@tiptap/markdown": "^3.25.0",
    "@tiptap/react": "^3.25.0",
    "@tiptap/starter-kit": "^3.25.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "i18next": "^26.3.4",
    "lucide-react": "1.23.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "7.18.1",
    "sigma": "^3.0.3",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "size-limit": [
    {
      "name": "main entry chunk",
      "path": "dist/assets/index-*.js",
      "limit": "150 KB",
      "gzip": true
    },
    {
      "name": "Sigma vendor chunk",
      "path": "dist/assets/vendor-sigma-*.js",
      "limit": "200 KB",
      "gzip": true
    },
    {
      "name": "Tiptap vendor chunk",
      "path": "dist/assets/vendor-tiptap-*.js",
      "limit": "180 KB",
      "gzip": true
    }
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hey-api/openapi-ts": "0.99.0",
    "@playwright/test": "^1.60.0",
    "@size-limit/file": "^12.1.0",
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-themes": "^10.4.2",
    "@storybook/react": "^10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/eslint-plugin-query": "5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "graphology-types": "^0.24.8",
    "js-yaml": "^5.2.1",
    "jscpd": "5.0.12",
    "jsdom": "^29.1.1",
    "knip": "^6.24.0",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "prettier": "3.9.5",
    "size-limit": "^12.1.0",
    "storybook": "^10.4.2",
    "swagger-ui-dist": "5.32.8",
    "tailwindcss": "^4.3.2",
    "ts-prune": "^0.10.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "@scarf/scarf": false,
    "esbuild@0.28.1": true,
    "msw@2.14.6": true
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
