{
  "suiteId": "synthetic_associative_graph_ranker",
  "description": "Release-blocking synthetic benchmark for associative multi-hop graph ranking and grounded graph evidence.",
  "strictBlocking": true,
  "documents": [
    "corpus/graph/alpha_relay_topology.md",
    "corpus/graph/beacon_transition_topology.md",
    "corpus/graph/needle_disambiguation_topology.md"
  ],
  "cases": [
    {
      "id": "two_hop_bridge_returns_endpoint",
      "question": "Which endpoint does Alpha Relay reach through Bridge Junction, and what route name connects the bridge to that endpoint?",
      "searchQuery": "Alpha Relay Bridge Junction Gamma Endpoint route name",
      "expectedDocumentsContains": ["alpha_relay_topology"],
      "searchRequiredAll": ["Alpha Relay", "Bridge Junction", "Gamma Endpoint"],
      "answerRequiredAll": ["Alpha Relay", "Bridge Junction", "Gamma Endpoint", "Bridge Gamma Route"],
      "answerForbiddenAny": ["Ordinary Artifact"],
      "expectedEntityReferenceLabelsContains": ["Alpha Relay", "Bridge Junction", "Gamma Endpoint"],
      "expectedRelationReferenceTextContains": ["Bridge Gamma Route"],
      "minChunkReferenceCount": 2,
      "minPreparedSegmentReferenceCount": 1,
      "minTechnicalFactReferenceCount": 0,
      "minEntityReferenceCount": 2,
      "minRelationReferenceCount": 1,
      "allowedVerificationStates": ["verified"]
    },
    {
      "id": "multi_anchor_event_beats_single_anchor_noise",
      "question": "Which transition joins Beacon Node with Harbor Delta, and which archive records the transition?",
      "searchQuery": "Beacon Node Harbor Delta transition archive",
      "expectedDocumentsContains": ["beacon_transition_topology"],
      "searchRequiredAll": ["Beacon Node", "Harbor Delta", "Beacon Harbor Transition"],
      "answerRequiredAll": ["Beacon Node", "Harbor Delta", "Beacon Harbor Transition", "Delta Archive"],
      "answerForbiddenAny": ["Single Anchor Note"],
      "expectedEntityReferenceLabelsContains": ["Beacon Node", "Harbor Delta", "Beacon Harbor Transition"],
      "expectedRelationReferenceTextContains": ["Beacon Harbor Transition"],
      "minChunkReferenceCount": 1,
      "minPreparedSegmentReferenceCount": 1,
      "minTechnicalFactReferenceCount": 0,
      "minEntityReferenceCount": 3,
      "minRelationReferenceCount": 1,
      "allowedVerificationStates": ["verified"]
    },
    {
      "id": "relationship_text_disambiguates_same_source",
      "question": "From Router Hub, which artifact is selected by the guarded needle route, and which artifact is only ordinary noise?",
      "searchQuery": "Router Hub guarded needle route Needle Artifact Ordinary Artifact",
      "expectedDocumentsContains": ["needle_disambiguation_topology"],
      "searchRequiredAll": ["Router Hub", "Needle Artifact", "Ordinary Artifact"],
      "answerRequiredAll": ["Needle Artifact", "Ordinary Artifact", "guarded needle route"],
      "answerForbiddenAny": ["Ordinary Artifact is selected"],
      "expectedEntityReferenceLabelsContains": ["Router Hub", "Needle Artifact"],
      "expectedRelationReferenceTextContains": ["guarded needle route"],
      "minChunkReferenceCount": 2,
      "minPreparedSegmentReferenceCount": 1,
      "minTechnicalFactReferenceCount": 0,
      "minEntityReferenceCount": 2,
      "minRelationReferenceCount": 1,
      "allowedVerificationStates": ["verified"]
    },
    {
      "id": "graph_backed_answer_does_not_pass_with_chunks_only",
      "question": "Which graph entities prove that Alpha Relay reaches Gamma Endpoint indirectly instead of directly?",
      "searchQuery": "Alpha Relay reaches Gamma Endpoint indirectly graph entities",
      "expectedDocumentsContains": ["alpha_relay_topology"],
      "searchRequiredAll": ["Alpha Relay", "Gamma Endpoint", "Bridge Junction"],
      "answerRequiredAll": ["Alpha Relay", "Bridge Junction", "Gamma Endpoint"],
      "answerForbiddenAny": ["directly reaches Gamma Endpoint"],
      "expectedEntityReferenceLabelsContains": ["Alpha Relay", "Bridge Junction", "Gamma Endpoint"],
      "expectedRelationReferenceTextContains": ["Bridge Junction"],
      "minChunkReferenceCount": 1,
      "minPreparedSegmentReferenceCount": 1,
      "minTechnicalFactReferenceCount": 0,
      "minEntityReferenceCount": 3,
      "minRelationReferenceCount": 1,
      "allowedVerificationStates": ["verified"]
    }
  ]
}
