## Canonical application config reference.
## For Docker Compose, copy `./.env.example` to `./.env`.
## For direct API/worker runs, export values from this file.
## Use only canonical `IRONRAG_*` variables; lower-case aliases are not supported.

IRONRAG_BIND_ADDR=0.0.0.0:8080
# Canonical values: api, worker, startup
IRONRAG_SERVICE_ROLE=api
# Stable process identity used in logs, worker leases and recovery audit.
# Use only ASCII letters, digits, '.', '_' or '-'.
IRONRAG_SERVICE_NAME=ironrag-backend
IRONRAG_ENVIRONMENT=local
# Optional stable telemetry id. It is only used when OTLP export is explicitly
# enabled; otherwise IronRAG does not derive or attach a deployment id.
# IRONRAG_DEPLOYMENT_ID=
IRONRAG_DATABASE_URL=postgres://postgres:postgres@postgres:5432/ironrag
IRONRAG_DATABASE_MAX_CONNECTIONS=20
IRONRAG_REDIS_URL=redis://redis:6379
IRONRAG_LOG_FILTER=info
# Comma-separated canonical browser origins. This is both the UI CORS allowlist
# and the MCP Streamable HTTP Origin allowlist; omit Origin for native clients.
IRONRAG_FRONTEND_ORIGIN=http://127.0.0.1:19000,http://localhost:19000
# Optional canonical public API origin. OpenAPI advertises it and MCP admits it
# as an exact Origin value (paths in the spec already include /v1).
# IRONRAG_OPENAPI_PUBLIC_ORIGIN=
IRONRAG_UI_SESSION_SECRET=local-ui-session-secret
# Dedicated at-rest credential key: canonical standard-base64 for exactly 32
# random bytes. Keep it in a secret manager, separate from the database
# password. Required only when storing/updating an AI or webhook secret.
# IRONRAG_CREDENTIAL_MASTER_KEY=
# Optional active key ID for v3 envelopes; defaults to `default` for backwards
# compatibility when only IRONRAG_CREDENTIAL_MASTER_KEY is set.
# IRONRAG_CREDENTIAL_MASTER_KEY_ID=current-2026
# Up to 8 previous keys for read/rewrap only. Entries must be lowercase-ID,
# comma-separated, whitespace-free and strictly sorted by ID.
# IRONRAG_CREDENTIAL_PREVIOUS_MASTER_KEYS=old-2025=<base64-key>,old-2026=<base64-key>
# First deploy dual-read code with writes disabled across every replica, then
# enable in a second rollout. Fresh single-version local stacks may use true.
IRONRAG_CREDENTIAL_ENCRYPTION_WRITE_ENABLED=false
IRONRAG_UI_DEFAULT_LOCALE=ru
IRONRAG_STARTUP_AUTHORITY_MODE=not_required
IRONRAG_DEPENDENCY_POSTGRES_MODE=external
IRONRAG_DEPENDENCY_REDIS_MODE=external
IRONRAG_DEPENDENCY_OBJECT_STORAGE_MODE=disabled
IRONRAG_CONTENT_STORAGE_PROVIDER=filesystem
IRONRAG_CONTENT_STORAGE_TOPOLOGY=single_node
IRONRAG_CONTENT_STORAGE_ROOT=/var/lib/ironrag/content-storage
IRONRAG_CONTENT_STORAGE_KEY_PREFIX=
IRONRAG_INGESTION_MAX_PARALLEL_JOBS_GLOBAL=64
IRONRAG_INGESTION_MAX_PARALLEL_JOBS_PER_WORKSPACE=16
IRONRAG_INGESTION_MAX_PARALLEL_JOBS_PER_LIBRARY=4
IRONRAG_DOCLING_PAGE_BATCH_SIZE=10
IRONRAG_DOCLING_PAGE_STREAM_WINDOW_PAGES=40
IRONRAG_DOCLING_MAX_CONCURRENCY=auto
IRONRAG_INGESTION_HEAVY_PIPELINE_PARALLELISM=auto
IRONRAG_INGESTION_EMBEDDING_PARALLELISM=8
IRONRAG_INGESTION_GRAPH_EXTRACT_PARALLELISM_PER_DOC=16
# Shared per-provider query/ingest concurrency budget. `0`/`0` is explicit
# unlimited mode; bounded defaults protect upstreams from fan-out storms.
IRONRAG_PROVIDER_CONCURRENCY_MAX_OUTBOUND=16
IRONRAG_PROVIDER_CONCURRENCY_QUERY_RESERVED=4
IRONRAG_PROVIDER_CONCURRENCY_ACQUIRE_TIMEOUT_MS=30000
IRONRAG_PROVIDER_CONCURRENCY_REGISTRY_MAX_ENTRIES=64
IRONRAG_PROVIDER_CONCURRENCY_REGISTRY_IDLE_TTL_SECONDS=900
# OpenTelemetry export is OFF by default. To opt in, set both enabled=true and
# an endpoint for a collector you control. Logs may contain query/document
# content and require a separate exporter opt-in. Protocol: grpc,
# http/protobuf or http/json.
IRONRAG_OTEL_ENABLED=false
# OTEL_SERVICE_NAME=ironrag-backend
# OTEL_RESOURCE_ATTRIBUTES=service.namespace=ironrag
# OTEL_DEPLOYMENT_ENVIRONMENT=prod
# OTEL_TRACES_EXPORTER=otlp
# OTEL_METRICS_EXPORTER=otlp
# OTEL_LOGS_EXPORTER=none                # otlp also ships content-bearing logs
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com:4317
# OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=cumulative
# S3 profile requires provider=s3, topology=shared_cluster, dependency_object_storage_mode=bundled|external.
# IRONRAG_CONTENT_STORAGE_S3_BUCKET=ironrag
# IRONRAG_CONTENT_STORAGE_S3_ENDPOINT=http://127.0.0.1:9000
# IRONRAG_CONTENT_STORAGE_S3_REGION=us-east-1
# IRONRAG_CONTENT_STORAGE_S3_ACCESS_KEY_ID=ironrag
# IRONRAG_CONTENT_STORAGE_S3_SECRET_ACCESS_KEY=ironrag-dev-secret
# IRONRAG_CONTENT_STORAGE_S3_SESSION_TOKEN=
# IRONRAG_CONTENT_STORAGE_S3_FORCE_PATH_STYLE=true
# Optional provider secrets for first-run AI bootstrap. When set, the login bootstrap screen can
# reuse them and startup can auto-apply canonical bindings for the default workspace/library.
# Provider-kind keys are matched exactly (no case folding or aliases). Encode
# the compact JSON with standard base64 so dotenv cannot reinterpret secrets.
IRONRAG_AI_PROVIDER_API_KEYS_JSON_B64=
# Optional first-run model defaults. The UI still shows these choices and lets the operator adjust
# them before finishing bootstrap.
# IRONRAG_UI_BOOTSTRAP_EXTRACT_GRAPH_PROVIDER_KIND=openai
# IRONRAG_UI_BOOTSTRAP_EXTRACT_GRAPH_MODEL_NAME=gpt-5.4
# IRONRAG_UI_BOOTSTRAP_EMBED_CHUNK_PROVIDER_KIND=openai
# IRONRAG_UI_BOOTSTRAP_EMBED_CHUNK_MODEL_NAME=text-embedding-3-large
# IRONRAG_UI_BOOTSTRAP_QUERY_COMPILE_PROVIDER_KIND=openai
# IRONRAG_UI_BOOTSTRAP_QUERY_COMPILE_MODEL_NAME=gpt-5.4-nano
# IRONRAG_UI_BOOTSTRAP_QUERY_ANSWER_PROVIDER_KIND=openai
# IRONRAG_UI_BOOTSTRAP_QUERY_ANSWER_MODEL_NAME=gpt-5.4
# IRONRAG_UI_BOOTSTRAP_AGENT_PROVIDER_KIND=openai
# IRONRAG_UI_BOOTSTRAP_AGENT_MODEL_NAME=gpt-5.4
# IRONRAG_UI_BOOTSTRAP_EXTRACT_TEXT_PROVIDER_KIND=openai
# IRONRAG_UI_BOOTSTRAP_EXTRACT_TEXT_MODEL_NAME=gpt-5.4-mini
IRONRAG_LLM_TRANSPORT_RETRY_ATTEMPTS=3
IRONRAG_LLM_TRANSPORT_RETRY_BASE_DELAY_MS=250
IRONRAG_QUERY_INTENT_CACHE_TTL_HOURS=24
IRONRAG_QUERY_INTENT_CACHE_MAX_ENTRIES_PER_LIBRARY=500
# Filtered pgvector HNSW search bounds. Exact fallback is attempted only when
# an underfilled logical lane has at most this many manifest rows; 0 disables it.
IRONRAG_PG_HNSW_EF_SEARCH=400
IRONRAG_PG_HNSW_MAX_SCAN_TUPLES=50000
IRONRAG_PG_HNSW_SCAN_MEM_MULTIPLIER=2
IRONRAG_PG_HNSW_EXACT_FALLBACK_MAX_ROWS=10000
IRONRAG_QUERY_RERANK_ENABLED=true
IRONRAG_QUERY_RERANK_CANDIDATE_LIMIT=24
# Optional provider-backed rerank: off, shadow, or active. Both provider modes
# send the query and bounded candidate excerpts through the configured
# QueryCompile profile. Shadow never changes ordering; active falls back deterministically.
IRONRAG_QUERY_SEMANTIC_RERANK_MODE=off
IRONRAG_QUERY_SEMANTIC_RERANK_TIMEOUT_MS=1500
IRONRAG_QUERY_SEMANTIC_RERANK_CANDIDATE_LIMIT=16
IRONRAG_QUERY_SEMANTIC_RERANK_CANDIDATE_TEXT_CHARS=1200
IRONRAG_QUERY_SEMANTIC_RERANK_TOTAL_TEXT_CHARS=18000
IRONRAG_QUERY_BALANCED_CONTEXT_ENABLED=true
IRONRAG_QUERY_ANSWER_SOURCE_LINKS_ENABLED=false
IRONRAG_RELEASE_CHECK_REPOSITORY=mlimarenko/IronRAG
IRONRAG_RELEASE_CHECK_INTERVAL_HOURS=12
IRONRAG_RUNTIME_GRAPH_EXTRACT_RECOVERY_ENABLED=true
IRONRAG_RUNTIME_GRAPH_EXTRACT_RECOVERY_MAX_ATTEMPTS=2
IRONRAG_RUNTIME_GRAPH_EXTRACT_IDLE_TIMEOUT_SECONDS=300
IRONRAG_RUNTIME_GRAPH_EXTRACT_RESUME_DOWNGRADE_LEVEL_ONE_AFTER_REPLAYS=3
IRONRAG_RUNTIME_GRAPH_EXTRACT_RESUME_DOWNGRADE_LEVEL_TWO_AFTER_REPLAYS=5
IRONRAG_RUNTIME_GRAPH_SUMMARY_REFRESH_BATCH_SIZE=64
IRONRAG_RUNTIME_GRAPH_TARGETED_RECONCILIATION_ENABLED=true
IRONRAG_RUNTIME_GRAPH_TARGETED_RECONCILIATION_MAX_TARGETS=128
IRONRAG_RUNTIME_DOCUMENT_ACTIVITY_FRESHNESS_SECONDS=45
IRONRAG_RUNTIME_DOCUMENT_STALLED_AFTER_SECONDS=180
IRONRAG_RUNTIME_GRAPH_FILTER_EMPTY_RELATIONS=true
IRONRAG_RUNTIME_GRAPH_FILTER_DEGENERATE_SELF_LOOPS=true
IRONRAG_RUNTIME_GRAPH_CONVERGENCE_WARNING_BACKLOG_THRESHOLD=1
# MCP memory defaults for external agent reads/search. Increase only if clients need wider windows.
IRONRAG_MCP_MEMORY_DEFAULT_READ_WINDOW_CHARS=12000
IRONRAG_MCP_MEMORY_MAX_READ_WINDOW_CHARS=50000
IRONRAG_MCP_MEMORY_DEFAULT_SEARCH_LIMIT=10
IRONRAG_MCP_MEMORY_MAX_SEARCH_LIMIT=25
# Retention is used by upcoming MCP mutation idempotency receipts.
IRONRAG_MCP_MEMORY_IDEMPOTENCY_RETENTION_HOURS=72
# Set to false to disable persisted MCP audit writes once audit flow lands.
IRONRAG_MCP_MEMORY_AUDIT_ENABLED=true
