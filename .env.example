# Docker Compose reads this file from the repository root automatically.
# Keep only canonical IRONRAG_* and standard OTEL_* variables here; do not mix lower-case aliases.
# A single docker-compose.yml serves every mode (prebuilt images + filesystem
# storage by default); the optional stanzas at the bottom of this file switch on
# the source build, the s4 object-storage profile, or larger memory caps.

# Published HTTP port for frontend -> UI/API/MCP.
IRONRAG_PORT=19000

# Basic stack defaults for the default (filesystem) stack.
# Free-form environment label (e.g. production, staging). Per-deployment
# uniqueness in telemetry comes from IRONRAG_DEPLOYMENT_ID, not this label.
IRONRAG_ENVIRONMENT=production
# Stable per-deployment telemetry id. Leave empty to auto-derive a UUID from the
# Postgres cluster identity (unique per stack, stable across recreation, shared
# by every role). Set a value only to override or when stacks share one DB.
# IRONRAG_DEPLOYMENT_ID=
IRONRAG_POSTGRES_DB=ironrag
IRONRAG_POSTGRES_USER=postgres
IRONRAG_POSTGRES_PASSWORD=postgres
IRONRAG_DATABASE_MAX_CONNECTIONS=20
IRONRAG_LOG_FILTER=info
IRONRAG_FRONTEND_ORIGIN=http://127.0.0.1:19000,http://localhost:19000
# Optional first-login bootstrap.
IRONRAG_UI_BOOTSTRAP_ADMIN_LOGIN=
IRONRAG_UI_BOOTSTRAP_ADMIN_PASSWORD=
IRONRAG_UI_BOOTSTRAP_ADMIN_API_TOKEN=

# Optional first-run model defaults.
IRONRAG_UI_BOOTSTRAP_EXTRACT_GRAPH_PROVIDER_KIND=openai
IRONRAG_UI_BOOTSTRAP_EXTRACT_GRAPH_MODEL_NAME=gpt-5.4-nano
IRONRAG_UI_BOOTSTRAP_EMBED_CHUNK_PROVIDER_KIND=openai
IRONRAG_UI_BOOTSTRAP_EMBED_CHUNK_MODEL_NAME=text-embedding-3-large
IRONRAG_UI_BOOTSTRAP_QUERY_ANSWER_PROVIDER_KIND=openai
IRONRAG_UI_BOOTSTRAP_QUERY_ANSWER_MODEL_NAME=gpt-5.4-mini
IRONRAG_UI_BOOTSTRAP_VISION_PROVIDER_KIND=openai
IRONRAG_UI_BOOTSTRAP_VISION_MODEL_NAME=gpt-5.4-mini

# Optional provider secrets.
IRONRAG_OPENAI_API_KEY=
IRONRAG_DEEPSEEK_API_KEY=
IRONRAG_QWEN_API_KEY=
IRONRAG_GPTUNNEL_API_KEY=
IRONRAG_OPENROUTER_API_KEY=
IRONRAG_ROUTERAI_API_KEY=
IRONRAG_MINIMAX_API_KEY=

# Optional Docker DNS overrides for app containers. Defaults in
# the Compose file use public recursive resolvers; set these when your
# deployment must resolve through a private network resolver instead.
# IRONRAG_DOCKER_DNS_PRIMARY=1.1.1.1
# IRONRAG_DOCKER_DNS_SECONDARY=8.8.8.8

# Ingestion tuning.
IRONRAG_INGESTION_MAX_PARALLEL_JOBS_GLOBAL=4
IRONRAG_INGESTION_MAX_PARALLEL_JOBS_PER_WORKSPACE=2
IRONRAG_INGESTION_MAX_PARALLEL_JOBS_PER_LIBRARY=1
IRONRAG_DOCLING_PAGE_BATCH_SIZE=10
IRONRAG_DOCLING_PAGE_STREAM_WINDOW_PAGES=40
IRONRAG_DOCLING_MAX_CONCURRENCY=auto
IRONRAG_INGESTION_HEAVY_PIPELINE_PARALLELISM=auto
IRONRAG_INGESTION_EMBEDDING_PARALLELISM=8
IRONRAG_INGESTION_GRAPH_EXTRACT_PARALLELISM_PER_DOC=16

# Retrieval tuning.
# IRONRAG_QUERY_RERANK_ENABLED=true
# IRONRAG_QUERY_RERANK_CANDIDATE_LIMIT=20
# IRONRAG_QUERY_BALANCED_CONTEXT_ENABLED=true
# IRONRAG_QUERY_ANSWER_SOURCE_LINKS_ENABLED=false

# Web crawl defaults.
# IRONRAG_WEB_INGEST_HTTP_TIMEOUT_SECONDS=30
# IRONRAG_WEB_INGEST_MAX_REDIRECTS=5

# Optional runtime policy controls for operator smoke and intervention drills.
# IRONRAG_RUNTIME_POLICY_REJECT_TASK_KINDS=
# IRONRAG_RUNTIME_POLICY_REJECT_TARGET_KINDS=

# OpenTelemetry export.
# Performance telemetry (traces + metrics) is ON by default and ships to the
# project maintainers' collector (compiled-in default, see
# apps/api/observability.toml) to help improve the system. It carries timings,
# counters and identifiers (library/document/chunk UUIDs) — NOT your documents,
# queries, answers or credentials. Logs are the only content-bearing signal and
# are OFF by default (OTEL_LOGS_EXPORTER=none below). All optional:
#   - disable everything:      IRONRAG_OTEL_ENABLED=false
#   - send to your collector:  set OTEL_EXPORTER_OTLP_ENDPOINT (+ PROTOCOL)
#   - also ship logs:          OTEL_LOGS_EXPORTER=otlp (includes content)
# IRONRAG_OTEL_ENABLED=true
# OTEL_RESOURCE_ATTRIBUTES=service.namespace=ironrag
# OTEL_DEPLOYMENT_ENVIRONMENT=prod
# OTEL_TRACES_EXPORTER=otlp
# OTEL_METRICS_EXPORTER=otlp
# OTEL_LOGS_EXPORTER=none
# OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=cumulative
# Override the shipped sink with your own collector (gRPC on :4317):
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com:4317
# or HTTP/protobuf on :4318:
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com:4318
# Browser traces are baked into the frontend image at build time.
# VITE_OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com:4318/v1/traces
# VITE_OTEL_SERVICE_NAME=ironrag-web
# VITE_OTEL_DEPLOYMENT_ENVIRONMENT=prod
# Local frontend developer tools are opt-in so they do not leak into normal UI
# screenshots or demos.
# VITE_ENABLE_QUERY_DEVTOOLS=false

# Optional image overrides for prebuilt or internal deployments.
# IRONRAG_BACKEND_IMAGE=pipingspace/ironrag-backend:latest
# IRONRAG_FRONTEND_IMAGE=pipingspace/ironrag-frontend:latest
# IRONRAG_POSTGRES_IMAGE=postgres:18-alpine
# IRONRAG_REDIS_IMAGE=redis:8.8
# IRONRAG_S4CORE_IMAGE=s4core/s4core:latest

# ── Optional: S3 object storage via the bundled s4core (`s4` profile) ────────
# Uncomment all of these together. COMPOSE_PROFILES starts the s4core service;
# the three storage knobs switch IronRAG from filesystem to S3. Endpoint and
# credentials already default to the bundled s4core — override the S3_* vars to
# point at an external bucket instead.
# COMPOSE_PROFILES=s4
# IRONRAG_CONTENT_STORAGE_PROVIDER=s3
# IRONRAG_DEPENDENCY_OBJECT_STORAGE_MODE=bundled
# IRONRAG_CONTENT_STORAGE_TOPOLOGY=shared_cluster
# IRONRAG_CONTENT_STORAGE_S3_BUCKET=ironrag
# IRONRAG_CONTENT_STORAGE_S3_ACCESS_KEY_ID=ironrag
# IRONRAG_CONTENT_STORAGE_S3_SECRET_ACCESS_KEY=ironrag-dev-secret

# ── Optional: local source build instead of pulling published images ─────────
# Run `docker compose up -d --build` (or `make docker-local-up`) after setting.
# IRONRAG_BACKEND_IMAGE=ironrag-backend:local
# IRONRAG_FRONTEND_IMAGE=ironrag-frontend:local

# ── Optional: host sizing — tune per-role CPU and memory caps ────────────────
# The defaults are Docling-capable (≈5.4 GiB steady-state Σ) so one embedded
# extractor can run without relying on kernel OOM recovery. Raise BOTH the CPU
# and memory limit per role for bigger hosts and corpora, or lower the worker
# only for text/native-only local stacks. Same var names as docker-compose.yml;
# values shown are examples for a 16 GiB host, not requirements.
# IRONRAG_FRONTEND_CPUS=1.00
# IRONRAG_FRONTEND_MEMORY_LIMIT=256M
# IRONRAG_CACHE_CPUS=1.00
# IRONRAG_CACHE_MEMORY_LIMIT=768M
# IRONRAG_DB_CPUS=2.00
# IRONRAG_DB_MEMORY_LIMIT=4096M
# IRONRAG_WORKER_CPUS=6.00
# IRONRAG_WORKER_MEMORY_LIMIT=3072M
# IRONRAG_BACKEND_CPUS=6.00
# IRONRAG_BACKEND_MEMORY_LIMIT=3584M
# IRONRAG_S4CORE_CPUS=2.00
# IRONRAG_S4CORE_MEMORY_LIMIT=1024M

# ── Optional: local-dev convenience overrides ────────────────────────────────
# A small local graph-extraction model (e.g. Ollama) can exceed the baked 300s
# idle timeout; raise it for CPU/GPU-constrained runs.
# IRONRAG_RUNTIME_GRAPH_EXTRACT_IDLE_TIMEOUT_SECONDS=1800

# Advanced runtime overrides such as external dependency URLs or manual deployment modes
# are intentionally not listed here to keep the common compose path small.
# See apps/api/.env.example when you need the full runtime surface.
