RUSTRAG_BIND_ADDR=0.0.0.0:8080
RUSTRAG_SERVICE_NAME=rustrag-backend
RUSTRAG_ENVIRONMENT=local
RUSTRAG_DATABASE_URL=postgres://postgres:postgres@postgres:5432/rustrag
RUSTRAG_DATABASE_MAX_CONNECTIONS=20
RUSTRAG_REDIS_URL=redis://redis:6379
RUSTRAG_NEO4J_URI=127.0.0.1:7687
RUSTRAG_NEO4J_USERNAME=neo4j
RUSTRAG_NEO4J_PASSWORD=rustrag-dev
RUSTRAG_NEO4J_DATABASE=neo4j
RUSTRAG_NEO4J_MAX_CONNECTIONS=16
RUSTRAG_LOG_FILTER=info
RUSTRAG_BOOTSTRAP_TOKEN=
RUSTRAG_OPENAI_API_KEY=
RUSTRAG_DEEPSEEK_API_KEY=
RUSTRAG_QWEN_API_KEY=
RUSTRAG_QWEN_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
RUSTRAG_INGESTION_WORKER_CONCURRENCY=4
RUSTRAG_RUNTIME_DEFAULT_INDEXING_PROVIDER=openai
RUSTRAG_RUNTIME_DEFAULT_INDEXING_MODEL=gpt-5-mini
RUSTRAG_RUNTIME_DEFAULT_EMBEDDING_PROVIDER=openai
RUSTRAG_RUNTIME_DEFAULT_EMBEDDING_MODEL=text-embedding-3-large
RUSTRAG_RUNTIME_DEFAULT_ANSWER_PROVIDER=openai
RUSTRAG_RUNTIME_DEFAULT_ANSWER_MODEL=gpt-5.4
RUSTRAG_RUNTIME_DEFAULT_VISION_PROVIDER=openai
RUSTRAG_RUNTIME_DEFAULT_VISION_MODEL=gpt-5-mini
RUSTRAG_RUNTIME_LIVE_VALIDATION_ENABLED=true
RUSTRAG_RUNTIME_QUERY_INTENT_CACHE_TTL_HOURS=24
RUSTRAG_RUNTIME_QUERY_INTENT_CACHE_MAX_ENTRIES_PER_LIBRARY=500
RUSTRAG_RUNTIME_QUERY_RERANK_ENABLED=true
RUSTRAG_RUNTIME_QUERY_RERANK_CANDIDATE_LIMIT=24
RUSTRAG_RUNTIME_QUERY_BALANCED_CONTEXT_ENABLED=true
RUSTRAG_RUNTIME_GRAPH_EXTRACT_RECOVERY_ENABLED=true
RUSTRAG_RUNTIME_GRAPH_EXTRACT_RECOVERY_MAX_ATTEMPTS=2
RUSTRAG_RUNTIME_GRAPH_SUMMARY_REFRESH_BATCH_SIZE=64
RUSTRAG_RUNTIME_GRAPH_TARGETED_RECONCILIATION_ENABLED=true
RUSTRAG_RUNTIME_GRAPH_TARGETED_RECONCILIATION_MAX_TARGETS=128
RUSTRAG_RUNTIME_DOCUMENT_ACTIVITY_FRESHNESS_SECONDS=45
RUSTRAG_RUNTIME_DOCUMENT_STALLED_AFTER_SECONDS=180
RUSTRAG_RUNTIME_GRAPH_FILTER_EMPTY_RELATIONS=true
RUSTRAG_RUNTIME_GRAPH_FILTER_DEGENERATE_SELF_LOOPS=true
RUSTRAG_RUNTIME_GRAPH_CONVERGENCE_WARNING_BACKLOG_THRESHOLD=1
# Seed the pricing catalog from env defaults during bootstrap/migration utilities only.
# Runtime accounting should resolve prices from database rows once catalog entries exist.
RUSTRAG_RUNTIME_PRICING_SEED_FROM_ENV=true
RUSTRAG_RUNTIME_PRICING_DEFAULT_CURRENCY=USD
# Legacy env price values are treated as bootstrap seed inputs, not as authoritative runtime pricing.
RUSTRAG_OPENAI_INPUT_PRICE_PER_1M=0.25
RUSTRAG_OPENAI_OUTPUT_PRICE_PER_1M=2.0
RUSTRAG_DEEPSEEK_INPUT_PRICE_PER_1M=0.27
RUSTRAG_DEEPSEEK_OUTPUT_PRICE_PER_1M=1.10
RUSTRAG_QWEN_INPUT_PRICE_PER_1M=0.07
RUSTRAG_QWEN_CHAT_INPUT_PRICE_PER_1M=0
RUSTRAG_QWEN_CHAT_OUTPUT_PRICE_PER_1M=0
RUSTRAG_QWEN_VISION_INPUT_PRICE_PER_1M=0
RUSTRAG_QWEN_VISION_OUTPUT_PRICE_PER_1M=0
