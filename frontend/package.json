{
  "name": "rustrag-frontend",
  "version": "0.0.1",
  "description": "RustRAG frontend scaffold",
  "productName": "RustRAG Frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "quasar dev",
    "build": "quasar build",
    "lint": "eslint ./src ./quasar.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "api:generate": "openapi-typescript ../backend/contracts/rustrag.openapi.yaml -o ./src/contracts/api/generated.ts && prettier --write ./src/contracts/api/generated.ts",
    "api:check": "npm run api:generate && prettier --check ./src/contracts/api/generated.ts",
    "typecheck": "vue-tsc --noEmit",
    "test:run": "vitest run",
    "enterprise:check": "npm run api:check && npm run lint && npm run format:check && npm run typecheck && npm run build",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@quasar/extras": "^1.17.0",
    "axios": "^1.13.5",
    "pinia": "^3.0.4",
    "quasar": "^2.18.6",
    "vue": "^3.5.28",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@quasar/app-vite": "^2.4.1",
    "@types/node": "^25.2.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-typescript": "^14.6.0",
    "eslint": "^10.0.0",
    "eslint-plugin-vue": "^10.7.0",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.6.2",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.44.1",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.4"
  }
}
